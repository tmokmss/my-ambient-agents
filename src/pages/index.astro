---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { FileText, Search, AlertTriangle, Flame } from "@lucide/astro";

const reports = (await getCollection("reports")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const categoryIcons: Record<string, any> = { summary: FileText, analysis: Search, alert: AlertTriangle, buzz: Flame };

const allTags = [...new Set(reports.flatMap((r) => [`category:${r.data.category}`, ...(r.data.tags ?? [])]))].sort();
const PAGE_SIZE = 20;
---

<Layout title="Reports" showSubtitle>
  <div class="flex flex-wrap gap-3 mb-6 items-start">
    <div class="flex-1 min-w-[200px]">
      <input type="search" id="search-input" placeholder="全文検索..." autocomplete="off" class="w-full h-9 px-3 text-[0.8rem] border border-[var(--border)] rounded-lg bg-[var(--card-bg)] text-[var(--fg)] outline-none transition-[border-color] duration-150 focus:border-[var(--accent)] placeholder:text-[var(--muted)]" />
    </div>
    {allTags.length > 0 && (
      <div class="relative min-w-[200px] flex-1 max-w-xs max-sm:min-w-0 max-sm:max-w-none" id="tag-combo">
        <div class="relative flex items-center">
          <input class="w-full h-9 pr-8 pl-3 text-[0.8rem] border border-[var(--border)] rounded-lg bg-[var(--card-bg)] text-[var(--fg)] outline-none focus:border-[var(--accent)] placeholder:text-[var(--muted)]" id="tag-input" type="text" placeholder="タグで絞り込み..." autocomplete="off" />
          <button class="tag-clear absolute right-1.5 items-center justify-center w-5 h-5 border-none rounded-full bg-[var(--muted)] text-[var(--bg)] text-[0.7rem] leading-none cursor-pointer p-0 hover:bg-[var(--fg)]" id="tag-clear" aria-label="タグをクリア">&times;</button>
        </div>
        <ul class="tag-dropdown absolute top-full left-0 right-0 max-h-[200px] overflow-y-auto bg-[var(--card-bg)] border border-[var(--border)] border-t-0 rounded-b-lg z-10 list-none" id="tag-dropdown">
          {allTags.map((tag) => (
            <li class="tag-option px-3 py-1.5 text-[0.8rem] cursor-pointer text-[var(--fg)] hover:bg-[var(--code-bg)]" data-tag={tag}>{tag}</li>
          ))}
        </ul>
        <div class="flex flex-wrap gap-1 min-h-6 mt-1.5" id="selected-tags"></div>
      </div>
    )}
    <div class="flex items-center gap-2 max-sm:[&_label]:hidden max-sm:[&_.date-input]:w-full">
      <label for="date-until" class="text-[0.8rem] text-[var(--muted)] whitespace-nowrap">表示期間:</label>
      <input class="date-input h-9 px-3 text-[0.8rem] font-[inherit] border border-[var(--border)] rounded-lg bg-[var(--card-bg)] text-[var(--fg)] outline-none focus:border-[var(--accent)]" id="date-until" type="date" />
    </div>
  </div>

  {reports.length === 0 ? (
    <p class="text-[var(--muted)]">No reports yet. The agent will generate the first report on its next scheduled run.</p>
  ) : (
    <>
      <p class="text-[0.8rem] text-[var(--muted)] mb-4" id="result-count"></p>
      <ul class="list-none flex flex-col gap-4" id="report-list">
        {reports.map((report) => (
          <li class="report-card px-5 py-4 bg-[var(--card-bg)] border border-[var(--border)] rounded-lg flex gap-4 items-start" data-id={report.id} data-tags={JSON.stringify([`category:${report.data.category}`, ...(report.data.tags ?? [])])} data-date={new Date(report.data.date).toISOString().slice(0, 10)}>
            {() => {
              const Icon = categoryIcons[report.data.category];
              return Icon ? <span class="shrink-0 text-[var(--muted)] mt-0.5 [&_svg]:w-[18px] [&_svg]:h-[18px]"><Icon size={18} /></span> : null;
            }}
            <div class="min-w-0">
              <h2 class="text-base font-semibold mb-1"><a href={`${import.meta.env.BASE_URL}/reports/${report.id}/`}>{report.data.title}</a></h2>
              <div class="text-[0.8rem] text-[var(--muted)]">
                <time class="local-time" datetime={new Date(report.data.date).toISOString()}>{new Date(new Date(report.data.date).getTime() + 9 * 60 * 60 * 1000).toISOString().slice(0, 16).replace('T', ' ')} JST</time> &middot;
                <span>{report.data.category}</span>
              </div>
              <p class="text-sm mt-2">{report.data.summary}</p>
              {(report.data.tags ?? []).length > 0 && (
                <div class="flex flex-wrap gap-1 mt-2">
                  {(report.data.tags ?? []).map((tag) => (
                    <span class="text-[0.7rem] px-2 py-0.5 rounded-full bg-[var(--code-bg)] text-[var(--muted)]">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </li>
        ))}
      </ul>
      <div class="text-center mt-6" id="load-more-wrap">
        <button class="px-6 py-2 text-[0.85rem] border border-[var(--border)] rounded-lg bg-[var(--card-bg)] text-[var(--fg)] cursor-pointer transition-[border-color] duration-150 hover:border-[var(--accent)] hover:text-[var(--accent)]" id="load-more">もっと表示</button>
      </div>
    </>
  )}

  <script>
    import type MiniSearchType from 'minisearch';

    const PAGE_SIZE = 20;
    const BASE_URL = import.meta.env.BASE_URL;

    const allCards = Array.from(document.querySelectorAll<HTMLElement>('#report-list .report-card'));
    const loadMoreBtn = document.getElementById('load-more');
    const loadMoreWrap = document.getElementById('load-more-wrap');
    const resultCount = document.getElementById('result-count');
    const dateInput = document.getElementById('date-until') as HTMLInputElement | null;
    const tagInput = document.getElementById('tag-input') as HTMLInputElement | null;
    const tagClearBtn = document.getElementById('tag-clear');
    const dropdown = document.getElementById('tag-dropdown');
    const selectedTagsEl = document.getElementById('selected-tags');
    const searchInput = document.getElementById('search-input') as HTMLInputElement | null;

    if (allCards.length) {
      // --- URL query string sync ---
      const getParams = () => new URLSearchParams(window.location.search);

      const syncURL = () => {
        const params = new URLSearchParams();
        const q = searchInput?.value.trim() ?? '';
        if (q) params.set('q', q);
        if (activeTags.size > 0) params.set('tags', Array.from(activeTags).join(','));
        const d = dateInput?.value ?? '';
        if (d) params.set('date', d);
        const qs = params.toString();
        history.replaceState(null, '', window.location.pathname + (qs ? `?${qs}` : ''));
      };

      // Read initial state from URL
      const initParams = getParams();
      const activeTags = new Set<string>(
        initParams.get('tags')?.split(',').filter(Boolean) ?? []
      );
      let visibleCount = PAGE_SIZE;
      let searchMatchIds: Set<string> | null = null;

      // Restore date input
      if (dateInput && initParams.get('date')) {
        dateInput.value = initParams.get('date')!;
      }
      // Restore search input
      if (searchInput && initParams.get('q')) {
        searchInput.value = initParams.get('q')!;
      }

      // --- Full-text search (MiniSearch + Intl.Segmenter, lazy-loaded) ---
      const STOP_WORDS = new Set([
        'の', 'に', 'は', 'を', 'た', 'が', 'で', 'て', 'と', 'し',
        'れ', 'さ', 'ある', 'いる', 'も', 'する', 'から', 'な', 'こと',
        'として', 'い', 'や', 'など', 'なっ', 'ない', 'この', 'ため',
        'その', 'あっ', 'よう', 'また', 'もの', 'という', 'あり',
        'まで', 'られ', 'なる', 'へ', 'か', 'だ', 'これ', 'によって',
        'により', 'おり', 'より', 'による', 'ず', 'なり', 'られる',
        'において', 'ば', 'なかっ', 'なく', 'しかし', 'について',
        'せ', 'だっ', 'そう', 'それ', 'ところ', 'よ', 'ね',
      ]);

      const segmenter = typeof Intl !== 'undefined' && Intl.Segmenter
        ? new Intl.Segmenter('ja', { granularity: 'word' })
        : null;

      const tokenize = (text: string): string[] => {
        if (!text) return [];
        if (segmenter) {
          const tokens: string[] = [];
          for (const seg of segmenter.segment(text)) {
            if (seg.isWordLike && !STOP_WORDS.has(seg.segment)) {
              tokens.push(seg.segment.toLowerCase());
            }
          }
          return tokens;
        }
        return text.toLowerCase().split(/\s+/).filter(w => w && !STOP_WORDS.has(w));
      };

      let miniSearch: MiniSearchType | null = null;
      let searchLoadPromise: Promise<void> | null = null;

      const ensureSearchLoaded = (): Promise<void> => {
        if (miniSearch) return Promise.resolve();
        if (searchLoadPromise) return searchLoadPromise;

        searchLoadPromise = (async () => {
          if (searchInput) searchInput.placeholder = '検索インデックスを読み込み中...';

          const [{ default: MiniSearch }, indexRes] = await Promise.all([
            import('minisearch'),
            fetch(`${BASE_URL}/search-index.json`),
          ]);
          const index = await indexRes.json();

          miniSearch = MiniSearch.loadJSON(JSON.stringify(index), {
            fields: ['title', 'summary', 'body'],
            storeFields: ['id'],
            tokenize,
            searchOptions: { tokenize, prefix: true },
          });

          if (searchInput) searchInput.placeholder = '全文検索...';
        })();

        return searchLoadPromise;
      };

      if (searchInput) {
        // Lazy-load on focus
        searchInput.addEventListener('focus', () => { ensureSearchLoaded(); }, { once: true });

        let searchTimer: ReturnType<typeof setTimeout> | null = null;
        searchInput.addEventListener('input', () => {
          if (searchTimer) clearTimeout(searchTimer);
          searchTimer = setTimeout(async () => {
            const query = searchInput.value.trim();
            if (!query) {
              searchMatchIds = null;
            } else {
              await ensureSearchLoaded();
              const results = miniSearch!.search(query, { prefix: true });
              searchMatchIds = new Set(results.map(r => r.id));
            }
            applyFilters();
          }, 200);
        });

        // If query was restored from URL, load immediately
        if (initParams.get('q')) {
          ensureSearchLoaded().then(() => {
            const q = searchInput.value.trim();
            if (q && miniSearch) {
              const results = miniSearch.search(q, { prefix: true });
              searchMatchIds = new Set(results.map(r => r.id));
              render();
            }
          });
        }
      }

      // --- Tag combobox ---
      if (tagInput && dropdown) {
        const options = Array.from(dropdown.querySelectorAll<HTMLElement>('.tag-option'));

        const updateDropdown = () => {
          const query = tagInput.value.toLowerCase();
          let anyVisible = false;
          for (const opt of options) {
            const tag = opt.getAttribute('data-tag')!;
            const match = !query || tag.toLowerCase().includes(query);
            opt.style.display = match ? '' : 'none';
            opt.classList.toggle('selected', activeTags.has(tag));
            if (match) anyVisible = true;
          }
          dropdown.classList.toggle('open', anyVisible);
        };

        const renderSelectedTags = () => {
          selectedTagsEl!.innerHTML = '';
          for (const tag of activeTags) {
            const btn = document.createElement('button');
            btn.className = 'inline-flex items-center gap-1 text-[0.7rem] py-0.5 px-2 rounded-full bg-[var(--accent)] text-[var(--bg)] cursor-pointer border-none hover:opacity-80';
            btn.textContent = `${tag} \u00d7`;
            btn.addEventListener('click', () => {
              activeTags.delete(tag);
              renderSelectedTags();
              updateDropdown();
              applyFilters();
            });
            selectedTagsEl!.appendChild(btn);
          }
          tagClearBtn!.classList.toggle('visible', activeTags.size > 0);
        };

        tagInput.addEventListener('focus', () => updateDropdown());
        tagInput.addEventListener('input', () => updateDropdown());

        document.addEventListener('click', (e) => {
          if (!document.getElementById('tag-combo')?.contains(e.target as Node)) {
            dropdown.classList.remove('open');
          }
        });

        for (const opt of options) {
          opt.addEventListener('click', (e) => {
            e.stopPropagation();
            const tag = opt.getAttribute('data-tag')!;
            if (activeTags.has(tag)) {
              activeTags.delete(tag);
            } else {
              activeTags.add(tag);
            }
            tagInput.value = '';
            updateDropdown();
            renderSelectedTags();
            applyFilters();
          });
        }

        tagClearBtn!.addEventListener('click', () => {
          activeTags.clear();
          tagInput.value = '';
          renderSelectedTags();
          updateDropdown();
          applyFilters();
        });

        if (activeTags.size > 0) {
          renderSelectedTags();
        }
      }

      // --- Date filter ---
      if (dateInput) {
        dateInput.addEventListener('change', () => applyFilters());
      }

      // --- Filtering & pagination ---
      const getFilteredCards = () => {
        const dateVal = dateInput?.value ?? '';
        return allCards.filter(card => {
          if (searchMatchIds) {
            if (!searchMatchIds.has(card.getAttribute('data-id')!)) return false;
          }
          if (activeTags.size > 0) {
            const cardTags: string[] = JSON.parse(card.getAttribute('data-tags') || '[]');
            if (![...activeTags].some(t => cardTags.includes(t))) return false;
          }
          if (dateVal) {
            if (card.getAttribute('data-date')! > dateVal) return false;
          }
          return true;
        });
      };

      const applyFilters = () => {
        visibleCount = PAGE_SIZE;
        syncURL();
        render();
      };

      const render = () => {
        const filtered = getFilteredCards();
        for (const c of allCards) c.style.display = 'none';
        for (let i = 0; i < filtered.length && i < visibleCount; i++) {
          filtered[i].style.display = '';
        }
        if (resultCount) {
          const total = filtered.length;
          const shown = Math.min(visibleCount, total);
          resultCount.textContent = `${total}件中 ${shown}件表示`;
        }
        if (loadMoreWrap) {
          loadMoreWrap.style.display = visibleCount < filtered.length ? '' : 'none';
        }
      };

      // --- Load more ---
      if (loadMoreBtn) {
        loadMoreBtn.addEventListener('click', () => {
          visibleCount += PAGE_SIZE;
          render();
        });
      }

      // Initial render
      render();
    }
  </script>
</Layout>
