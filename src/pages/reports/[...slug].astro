---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { Copy, Check, MessageCircle, ExternalLink, ChevronLeft, ChevronRight } from "@lucide/astro";

export async function getStaticPaths() {
  const reports = await getCollection("reports");
  const sorted = reports.sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
  return sorted.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prev: sorted[i - 1] ?? null,
      next: sorted[i + 1] ?? null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content, headings } = await render(entry);
const tocHeadings = headings.filter(h => h.depth === 2);
---

<Layout title={entry.data.title}>
  <div class="report-layout">
  <article id="report-article">
    <h1 class="text-2xl mb-1">{entry.data.title}</h1>
    <div class="text-[0.8rem] text-[var(--muted)] mb-6">
      <time class="local-time" datetime={entry.data.date.toISOString()}>{new Date(entry.data.date.getTime() + 9 * 60 * 60 * 1000).toISOString().slice(0, 16).replace('T', ' ')} JST</time> &middot; {entry.data.category}
    </div>
    {(entry.data.tags ?? []).length > 0 && (
      <div class="flex flex-wrap gap-1 mt-2 mb-4">
        {(entry.data.tags ?? []).map((tag: string) => (
          <span class="text-[0.7rem] px-2 py-0.5 rounded-full bg-[var(--code-bg)] text-[var(--muted)]">{tag}</span>
        ))}
      </div>
    )}
    <Content />
    <div class="flex items-center gap-3 mt-8 flex-wrap">
      <a id="ask-claude" class="inline-flex items-center gap-1.5 h-11 px-4 bg-[var(--accent)] text-[var(--bg)] border border-transparent rounded-lg cursor-pointer transition-opacity duration-150 hover:opacity-85 text-[0.85rem] font-semibold no-underline [&_svg]:w-[18px] [&_svg]:h-[18px]" aria-label="Ask Claude" title="Ask Claude">
        <MessageCircle size={18} /> Ask Claude <ExternalLink size={14} />
      </a>
      <button class="copy-md inline-flex items-center justify-center w-11 h-11 bg-[var(--card-bg)] text-[var(--fg)] border border-[var(--border)] rounded-lg cursor-pointer transition-[border-color] duration-150 hover:border-[var(--accent)] [&_svg]:w-[18px] [&_svg]:h-[18px]" id="copy-md" aria-label="Copy as Markdown" title="Copy Markdown"
        data-markdown={entry.body}
      >
        <span class="icon-copy"><Copy size={18} /></span>
        <span class="icon-check"><Check size={18} /></span>
      </button>
    </div>
    <script is:inline type="application/json" id="report-meta" set:html={JSON.stringify({ title: entry.data.title, summary: entry.data.summary, rawUrl: `${Astro.site}my-ambient-agents/raw/${entry.id}.md` })} />
    <nav class="flex justify-between items-start gap-4 mt-12 pt-6 border-t border-[var(--border)]">
      {prev ? (
        <a href={`${import.meta.env.BASE_URL}/reports/${prev.id}/`} class="flex items-start gap-2 no-underline text-[var(--fg)] hover:text-[var(--accent)] transition-colors max-w-[48%]">
          <ChevronLeft size={20} class="shrink-0 mt-0.5" />
          <div>
            <div class="text-[0.7rem] text-[var(--muted)]">前の記事</div>
            <div class="text-[0.85rem] leading-snug">{prev.data.title}</div>
          </div>
        </a>
      ) : <div />}
      {next ? (
        <a href={`${import.meta.env.BASE_URL}/reports/${next.id}/`} class="flex items-start gap-2 no-underline text-[var(--fg)] hover:text-[var(--accent)] transition-colors max-w-[48%] ml-auto">
          <div class="text-right">
            <div class="text-[0.7rem] text-[var(--muted)]">次の記事</div>
            <div class="text-[0.85rem] leading-snug">{next.data.title}</div>
          </div>
          <ChevronRight size={20} class="shrink-0 mt-0.5" />
        </a>
      ) : <div />}
    </nav>
  </article>
  {tocHeadings.length >= 2 && (
    <aside class="toc-aside">
      <nav>
        <h2>目次</h2>
        <ul>
          {tocHeadings.map(h => (
            <li><a href={`#${h.slug}`}>{h.text}</a></li>
          ))}
        </ul>
      </nav>
    </aside>
  )}
  </div>

  <script>
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-aside a');
    if (tocLinks.length > 0) {
      const headingEls = Array.from(tocLinks).map(a =>
        document.getElementById(a.getAttribute('href')!.slice(1))
      ).filter(Boolean) as HTMLElement[];

      const observer = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            tocLinks.forEach(a => a.classList.remove('active'));
            const link = document.querySelector(`.toc-aside a[href="#${entry.target.id}"]`);
            link?.classList.add('active');
          }
        }
      }, { rootMargin: '0px 0px -70% 0px' });

      for (const el of headingEls) observer.observe(el);
    }
  </script>

  <script>
    const copyBtn = document.getElementById('copy-md')!;
    const markdown = copyBtn.getAttribute('data-markdown')!;
    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(markdown).then(() => {
        copyBtn.classList.add('copied');
        setTimeout(() => copyBtn.classList.remove('copied'), 2000);
      });
    });

    const meta = JSON.parse(document.getElementById('report-meta')!.textContent!);
    const askBtn = document.getElementById('ask-claude') as HTMLAnchorElement;
    const prompt = `${meta.title}\n${meta.summary}\n\n以下のURLのレポートを読んで、内容について質問に答えてください。\n${meta.rawUrl}`;
    askBtn.href = 'https://claude.ai/new?q=' + encodeURIComponent(prompt);
    askBtn.target = '_blank';
    askBtn.rel = 'noopener';
  </script>
</Layout>
