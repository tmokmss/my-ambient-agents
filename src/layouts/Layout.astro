---
import { Sun, Moon, Monitor, Bot } from "@lucide/astro";
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
    <title>{title} | Ambient Agents</title>
    <script is:inline>
      (function() {
        if (location.hostname === 'localhost' || location.hostname === '127.0.0.1') {
          document.title = '(Local) ' + document.title;
        }
        const saved = localStorage.getItem('theme');
        if (saved === 'light') document.documentElement.setAttribute('data-theme', 'light');
        else if (saved === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
      })();
    </script>
  </head>
  <body>
    <header class="mb-8 pb-4 border-b border-[var(--border)] flex justify-between items-start gap-4">
      <div class="min-w-0">
        <h1 class="text-xl font-semibold max-sm:text-[1.1rem]"><a href={import.meta.env.BASE_URL}>Ambient Agents</a></h1>
      </div>
      <div class="flex items-center gap-1 shrink-0">
      <a href="https://github.com/tmokmss/my-ambient-agents" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center w-9 h-9 rounded-lg text-[var(--muted)] transition-[color,background-color] duration-150 hover:text-[var(--fg)] hover:bg-[var(--card-bg)] [&_svg]:w-[18px] [&_svg]:h-[18px]" aria-label="GitHub">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
      </a>
      <a href={`${import.meta.env.BASE_URL}/agents/`} class="inline-flex items-center justify-center w-9 h-9 rounded-lg text-[var(--muted)] transition-[color,background-color] duration-150 hover:text-[var(--fg)] hover:bg-[var(--card-bg)] [&_svg]:w-[18px] [&_svg]:h-[18px]" aria-label="Agent Status">
        <Bot size={18} />
      </a>
      <button class="inline-flex items-center justify-center w-9 h-9 bg-transparent border-none rounded-lg text-[var(--muted)] cursor-pointer shrink-0 transition-[color,background-color] duration-150 hover:text-[var(--fg)] hover:bg-[var(--card-bg)] [&_svg]:w-[18px] [&_svg]:h-[18px]" id="theme-toggle" aria-label="Toggle theme">
        <span class="theme-icon" id="icon-system"><Monitor size={18} /></span>
        <span class="theme-icon" id="icon-light"><Sun size={18} /></span>
        <span class="theme-icon" id="icon-dark"><Moon size={18} /></span>
      </button>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <script>
      const btn = document.getElementById('theme-toggle')!;
      const icons: Record<string, HTMLElement> = {
        system: document.getElementById('icon-system')!,
        light: document.getElementById('icon-light')!,
        dark: document.getElementById('icon-dark')!,
      };
      const modes = ['system', 'light', 'dark'] as const;
      type Mode = (typeof modes)[number];
      const titles: Record<Mode, string> = { system: 'Theme: System', light: 'Theme: Light', dark: 'Theme: Dark' };

      const current = (): Mode => (localStorage.getItem('theme') as Mode) || 'system';

      const apply = (mode: Mode) => {
        if (mode === 'system') {
          document.documentElement.removeAttribute('data-theme');
          localStorage.removeItem('theme');
        } else {
          document.documentElement.setAttribute('data-theme', mode);
          localStorage.setItem('theme', mode);
        }
        btn.title = titles[mode];
        for (const key of Object.keys(icons)) {
          icons[key].classList.toggle('active', key === mode);
        }
      };

      apply(current());

      btn.addEventListener('click', () => {
        const next = modes[(modes.indexOf(current()) + 1) % modes.length];
        apply(next);
      });
    </script>
    <script>
      const times = document.querySelectorAll<HTMLTimeElement>('.local-time');
      for (const el of times) {
        const d = new Date(el.getAttribute('datetime')!);
        const jst = new Date(d.getTime() + 9 * 60 * 60 * 1000);
        el.textContent = jst.getUTCFullYear() + '-'
          + String(jst.getUTCMonth() + 1).padStart(2, '0') + '-'
          + String(jst.getUTCDate()).padStart(2, '0') + ' '
          + String(jst.getUTCHours()).padStart(2, '0') + ':'
          + String(jst.getUTCMinutes()).padStart(2, '0')
          + ' JST';
      }
    </script>
  </body>
</html>
