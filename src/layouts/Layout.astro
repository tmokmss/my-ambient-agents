---
import { Sun, Moon, Monitor } from "@lucide/astro";
import "../styles/global.css";

interface Props {
  title: string;
  showSubtitle?: boolean;
}

const { title, showSubtitle = false } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Ambient Agents</title>
    <script is:inline>
      (function() {
        const saved = localStorage.getItem('theme');
        if (saved === 'light') document.documentElement.setAttribute('data-theme', 'light');
        else if (saved === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
      })();
    </script>
  </head>
  <body>
    <header class="mb-8 pb-4 border-b border-[var(--border)] flex justify-between items-start gap-4">
      <div class="min-w-0">
        <h1 class="text-xl font-semibold max-sm:text-[1.1rem]"><a href={import.meta.env.BASE_URL}>Ambient Agents</a></h1>
        {showSubtitle && <p class="mt-1 text-sm text-[var(--muted)] max-sm:text-[0.8rem]">Autonomous reports generated by scheduled Claude agents</p>}
      </div>
      <button class="inline-flex items-center justify-center w-9 h-9 bg-transparent border-none rounded-lg text-[var(--muted)] cursor-pointer shrink-0 transition-[color,background-color] duration-150 hover:text-[var(--fg)] hover:bg-[var(--card-bg)] [&_svg]:w-[18px] [&_svg]:h-[18px]" id="theme-toggle" aria-label="Toggle theme">
        <span class="theme-icon" id="icon-system"><Monitor size={18} /></span>
        <span class="theme-icon" id="icon-light"><Sun size={18} /></span>
        <span class="theme-icon" id="icon-dark"><Moon size={18} /></span>
      </button>
    </header>
    <main>
      <slot />
    </main>
    <script is:inline>
      (function() {
        var btn = document.getElementById('theme-toggle');
        var icons = {
          system: document.getElementById('icon-system'),
          light: document.getElementById('icon-light'),
          dark: document.getElementById('icon-dark')
        };
        var modes = ['system', 'light', 'dark'];
        var titles = { system: 'Theme: System', light: 'Theme: Light', dark: 'Theme: Dark' };

        function current() {
          return localStorage.getItem('theme') || 'system';
        }

        function apply(mode) {
          if (mode === 'system') {
            document.documentElement.removeAttribute('data-theme');
            localStorage.removeItem('theme');
          } else {
            document.documentElement.setAttribute('data-theme', mode);
            localStorage.setItem('theme', mode);
          }
          btn.title = titles[mode];
          for (var key in icons) {
            icons[key].classList.toggle('active', key === mode);
          }
        }

        apply(current());

        btn.addEventListener('click', function() {
          var next = modes[(modes.indexOf(current()) + 1) % modes.length];
          apply(next);
        });
      })();
    </script>
    <script is:inline>
      (function() {
        var times = document.querySelectorAll('.local-time');
        for (var i = 0; i < times.length; i++) {
          var el = times[i];
          var d = new Date(el.getAttribute('datetime'));
          el.textContent = d.getFullYear() + '-'
            + String(d.getMonth() + 1).padStart(2, '0') + '-'
            + String(d.getDate()).padStart(2, '0') + ' '
            + String(d.getHours()).padStart(2, '0') + ':'
            + String(d.getMinutes()).padStart(2, '0');
        }
      })();
    </script>
  </body>
</html>
