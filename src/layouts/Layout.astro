---
import { Sun, Moon, Monitor } from "@lucide/astro";

interface Props {
  title: string;
  showSubtitle?: boolean;
}

const { title, showSubtitle = false } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Ambient Agents</title>
    <script is:inline>
      (function() {
        const saved = localStorage.getItem('theme');
        if (saved === 'light') document.documentElement.setAttribute('data-theme', 'light');
        else if (saved === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
      })();
    </script>
    <style is:global>
      /* Light theme */
      :root[data-theme="light"] {
        --bg: #fafafa;
        --fg: #1a1a1a;
        --accent: #0d9668;
        --muted: #666;
        --card-bg: #ffffff;
        --border: #e0e0e0;
        --code-bg: #f0f0f0;
      }
      /* Dark theme */
      :root[data-theme="dark"] {
        --bg: #0a0a0a;
        --fg: #e0e0e0;
        --accent: #6ee7b7;
        --muted: #888;
        --card-bg: #141414;
        --border: #222;
        --code-bg: #1a1a2e;
      }
      /* System default (no data-theme): use prefers-color-scheme */
      :root:not([data-theme]) {
        --bg: #0a0a0a;
        --fg: #e0e0e0;
        --accent: #6ee7b7;
        --muted: #888;
        --card-bg: #141414;
        --border: #222;
        --code-bg: #1a1a2e;
      }
      @media (prefers-color-scheme: light) {
        :root:not([data-theme]) {
          --bg: #fafafa;
          --fg: #1a1a1a;
          --accent: #0d9668;
          --muted: #666;
          --card-bg: #ffffff;
          --border: #e0e0e0;
          --code-bg: #f0f0f0;
        }
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: var(--bg);
        color: var(--fg);
        line-height: 1.7;
        max-width: 52rem;
        margin: 0 auto;
        padding: 3.5rem 4rem;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      header {
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
      }
      header .header-left { min-width: 0; }
      header .header-left h1 { font-size: 1.25rem; font-weight: 600; }
      header .header-left p { margin-top: 0.25rem; font-size: 0.875rem; color: var(--muted); }
      .theme-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.25rem;
        height: 2.25rem;
        background: transparent;
        border: none;
        border-radius: 0.5rem;
        color: var(--muted);
        cursor: pointer;
        flex-shrink: 0;
        transition: color 0.15s, background-color 0.15s;
      }
      .theme-toggle:hover { color: var(--fg); background: var(--card-bg); }
      .theme-toggle svg { width: 18px; height: 18px; }
      .theme-icon { display: none; }
      .theme-icon.active { display: flex; align-items: center; }

      @media (max-width: 640px) {
        body { padding: 2rem 1.5rem; }
        header .header-left h1 { font-size: 1.1rem; }
        header .header-left p { font-size: 0.8rem; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="header-left">
        <h1><a href={import.meta.env.BASE_URL}>Ambient Agents</a></h1>
        {showSubtitle && <p>Autonomous reports generated by scheduled Claude agents</p>}
      </div>
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
        <span class="theme-icon" id="icon-system"><Monitor size={18} /></span>
        <span class="theme-icon" id="icon-light"><Sun size={18} /></span>
        <span class="theme-icon" id="icon-dark"><Moon size={18} /></span>
      </button>
    </header>
    <main>
      <slot />
    </main>
    <script is:inline>
      (function() {
        var btn = document.getElementById('theme-toggle');
        var icons = {
          system: document.getElementById('icon-system'),
          light: document.getElementById('icon-light'),
          dark: document.getElementById('icon-dark')
        };
        var modes = ['system', 'light', 'dark'];
        var titles = { system: 'Theme: System', light: 'Theme: Light', dark: 'Theme: Dark' };

        function current() {
          return localStorage.getItem('theme') || 'system';
        }

        function apply(mode) {
          if (mode === 'system') {
            document.documentElement.removeAttribute('data-theme');
            localStorage.removeItem('theme');
          } else {
            document.documentElement.setAttribute('data-theme', mode);
            localStorage.setItem('theme', mode);
          }
          btn.title = titles[mode];
          for (var key in icons) {
            icons[key].classList.toggle('active', key === mode);
          }
        }

        apply(current());

        btn.addEventListener('click', function() {
          var next = modes[(modes.indexOf(current()) + 1) % modes.length];
          apply(next);
        });
      })();
    </script>
    <script is:inline>
      (function() {
        var times = document.querySelectorAll('.local-time');
        for (var i = 0; i < times.length; i++) {
          var el = times[i];
          var d = new Date(el.getAttribute('datetime'));
          el.textContent = d.getFullYear() + '-'
            + String(d.getMonth() + 1).padStart(2, '0') + '-'
            + String(d.getDate()).padStart(2, '0') + ' '
            + String(d.getHours()).padStart(2, '0') + ':'
            + String(d.getMinutes()).padStart(2, '0');
        }
      })();
    </script>
  </body>
</html>
